extends ../layout

block Content
  include ../menu
  .particles
  #container.main
    .articleWrap
      h3 !{article.title}
      h4 !{article.articleTime}
      .share-with
        .bdsharebuttonbox <a href="#" class="bds_more" data-cmd="more"></a><a href="#" class="bds_qzone" data-cmd="qzone" title="分享到QQ空间"></a><a href="#" class="bds_weixin" data-cmd="weixin" title="分享到微信"></a><a href="#" class="bds_copy" data-cmd="copy" title="分享到复制网址"></a><a href="#" class="bds_print" data-cmd="print" title="分享到打印"></a>
        .clear
        script.
          window._bd_share_config={
            "common":{
              "bdSnsKey":{},"bdText":"","bdMini":"2","bdMiniList":false,"bdPic":"","bdStyle":"1","bdSize":"32"
            },"share":{},"image":{"viewList":["qzone","weixin","copy","print"],"viewText":"分享到：","viewSize":"16"},
            "selectShare":{"bdContainerClass":null,"bdSelectMiniList":["qzone","weixin","copy","print"]}};
            with(document)0[(getElementsByTagName('head')[0]||body).appendChild(createElement('script')).src='http://bdimg.share.baidu.com/static/api/js/share.js?v=89860593.js?cdnversion='+~(-new Date()/36e5)];
      div.article-ct !{article.content}
      if article.comments
        each val,index in article.comments
          -var clnum = index == 0 ? 1 : index+1;
          .commentsli
            .comments-tit !{clnum++}楼:!{val.conmentsName}
              span !{val.conmentsTime}
            .comments-p !{val.conmentsContent}
      .cmts-link.hide
       a(class="add-comments-link btn",href="###") +添加评论
      .comments
       h5 +添加评论
       .list-both.commentsborder
        .list-left 称呼:
        .list-right
          input(type="input",class="comments-name")
       .list-both
        .list-left 内容:
        .list-right
          textarea(class="textarea-text comments-txt",rows="10",cols="10")
       .list-both
        .list-left.comments-veristr 验证码:
        .list-right
          input(type="input",class="comments-veri",placeholder="请计算右侧算式的结果")
       .list-both
        .list-left 
        .list-right
          a(href="###",class="btn btn-insert-comments",article-id="#{article._id}") +加上去
          span(class="notice-span")
      #disqus_thread
      script.
            /* * * CONFIGURATION VARIABLES: EDIT BEFORE PASTING INTO YOUR WEBPAGE * * */
            var disqus_shortname = 'physicslover'; // required: replace example with your forum shortname

            /* * * DON'T EDIT BELOW THIS LINE * * */
            (function() {
                var dsq = document.createElement('script'); dsq.type = 'text/javascript'; dsq.async = true;
                dsq.src = '//' + disqus_shortname + '.disqus.com/embed.js';
                (document.getElementsByTagName('head')[0] || document.getElementsByTagName('body')[0]).appendChild(dsq);
            })();
      noscript Please enable JavaScript to view the <a href="http://disqus.com/?ref_noscript">comments powered by Disqus.</a>
      a(href="http://disqus.com" class="dsq-brlink") comments powered by <span class="logo-disqus">Disqus</span>

    include ../friendlink
